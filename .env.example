# Public hostname users type into the browser, without http:// or https://.
# Include the port only if users must include it in the browser URL.
INTERLOCK_PUBLIC_HOST=interlock.example.local

# The host written into the frontend runtime config. Usually this is the same
# as INTERLOCK_PUBLIC_HOST because the gateway container reverse-proxies /api.
INTERLOCK_BACKEND_PUBLIC_HOST=interlock.example.local

# Keep false for an all-HTTP deployment. If pfSense HAProxy terminates HTTPS
# for browsers, set both values to true to avoid browser mixed-content and
# secure-cookie issues.
INTERLOCK_FRONTEND_SSL=false
INTERLOCK_COOKIE_SECURE=false

# Published Windows/Docker Desktop port for pfSense HAProxy to reach.
# Use 0.0.0.0 so other machines can reach the Windows host LAN IP.
# Example HAProxy backend target: http://<windows-lan-ip>:8080
# This is used by windows.noreverseproxy.docker-compose.yaml for local/pfSense deployments.
INTERLOCK_HTTP_BIND=0.0.0.0:8080

# Change these before first production use.
POSTGRES_DB=interlockdb
POSTGRES_USER=interlockadmin
POSTGRES_PASSWORD=change-this-postgres-password
INTERLOCK_DEFAULT_SUPERUSER_USERNAME=admin
INTERLOCK_DEFAULT_SUPERUSER_PASSWORD=change-this-admin-password

# Optional comma-separated additions.
INTERLOCK_ALLOWED_HOSTS=
INTERLOCK_CSRF_TRUSTED_ORIGINS=
INTERLOCK_CORS_ALLOWED_ORIGINS=

# Optional. If unset, persistent keys are generated into the backend-data volume.
INTERLOCK_DJANGO_SECRET_KEY=
INTERLOCK_FERNET_KEY=
